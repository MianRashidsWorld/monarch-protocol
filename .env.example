# Database (used by app and Prisma)
DATABASE_URL=postgresql://monarch:changeme@db:5432/monarch
POSTGRES_PASSWORD=changeme

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32-output

# Admin credentials (single user)
# Username is plain text
ADMIN_USERNAME=hunter
# Generate hash: make hash-password PASSWORD=yourpassword
# Then base64-encode the output: echo -n '<hash>' | base64
ADMIN_PASSWORD_HASH_B64=base64_encoded_bcrypt_hash_here

# Cron endpoint protection
CRON_SECRET=replace-with-random-secret
